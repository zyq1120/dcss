<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.masu.dcs.mapper.SysDocTemplateMapper">

    <resultMap id="BaseResultMap" type="cn.masu.dcs.entity.SysDocTemplate">
