            <result property="templateName" column="template_name" jdbcType="VARCHAR"/>
            <result property="templateCode" column="template_code" jdbcType="VARCHAR"/>
            <result property="targetKvConfig" column="target_kv_config" jdbcType="OTHER"/>
            <result property="targetTableConfig" column="target_table_config" jdbcType="OTHER"/>
            <result property="ruleConfig" column="rule_config" jdbcType="OTHER"/>
            <result property="status" column="status" jdbcType="TINYINT"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
            <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,template_name,template_code,
        target_kv_config,target_table_config,rule_config,
        status,create_time,update_time
